# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Apify
APIFY_API_TOKEN=

# LLM API (add your OpenAI key for AI message generation)
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_TOKEN=
ADMIN_PIN=

# Brave Search
BRAVE_SEARCH_API_KEY=
BRAVE_API_KEY=

# VNC Manager (runs on VPS)
VNC_MANAGER_URL=
VNC_API_KEY=
NEXT_PUBLIC_VNC_WS_HOST=

# GoLogin
GOLOGIN_API_TOKEN=

# AI Video Pipeline
ELEVENLABS_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# GoHighLevel (SMS via LeadConnector)
GHL_API_KEY=
GHL_LOCATION_ID=

# Memory MCP — bridges Claude Code on terminal to /api/memories
OUTREACH_MEMORY_MCP_KEY=

# Memory Vault (the file-tree memory at /agency/memory)
# Public HTTPS URL of the VPS file-server, exposed via Tailscale Funnel.
# Current value: https://srv1197943.taild42583.ts.net:8443/vault
MEMORY_VAULT_API_URL=
MEMORY_VAULT_TOKEN=

# Agent Workflows — visual multi-agent system at /agency/memory#agent-workflows
# Inngest is the durable execution engine (loops, retries, pause/approve, resume).
# Get keys at https://app.inngest.com/ -> Settings -> Event Keys / Signing Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Hard cap on workflow LLM spend per UTC day. Workflow-tick refuses to queue
# new runs once today's spend hits this. Default $25.
WORKFLOW_DAILY_BUDGET_USD=25
# The agent-runner Node service running on the VPS (vps-deliverables/agent-runner).
# Spawns Claude Code subagents from ~/.claude/agents/ markdown files.
AGENT_RUNNER_URL=
AGENT_RUNNER_TOKEN=
